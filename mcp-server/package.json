{
  "name": "llm-wiki-mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server exposing an llm-wiki vault (search / get / list / backlinks).",
  "type": "module",
  "private": true,
  "bin": {
    "llm-wiki-mcp": "src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
